# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

use_modular_headers!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

# Required for react-native-firebase with Firebase 11+ (Swift-based modules)
$RNFirebaseAsStaticFramework = true

target 'FinCoordApp' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Firebase 12.x moved FIRAuth/FIRAuthErrorCode to Swift.
    # FirebaseAuth-Swift.h is normally generated by Xcode during compilation,
    # but with static-library pods it isn't placed where modular-header imports
    # can find it. We drop in a pre-built stub so the build succeeds.
    stub_src  = File.expand_path('../scripts/FirebaseAuth-Swift.h', __dir__)
    stub_dest = File.join(installer.sandbox.root,
                          'Headers/Public/FirebaseAuth/FirebaseAuth-Swift.h')
    if File.exist?(stub_src) && !File.exist?(stub_dest)
      FileUtils.cp(stub_src, stub_dest)
      Pod::UI.puts '[Firebase] Installed FirebaseAuth-Swift.h stub.'
    end
  end
end
